{
  "name": "fastcomments-solidjs",
  "version": "1.0.0",
  "description": "A SolidJS library for FastComments",
  "author": "winrid",
  "license": "MIT",
  "repository": "fastcomments/fastcomments-solidjs",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "solid": "./dist/source/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly && tsc -p tsconfig.source.json && node scripts/add-source-extensions.mjs",
    "dev": "vite --config vite.demo.config.ts",
    "test": "vitest run",
    "build:demo": "node build-demo.mjs"
  },
  "engines": {
    "node": ">=16"
  },
  "peerDependencies": {
    "solid-js": "^1.8.0"
  },
  "dependencies": {
    "fastcomments-typescript": "^3.0.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.4.0",
    "jsdom": "^24.0.0",
    "solid-js": "^1.8.15",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vite-plugin-solid": "^2.10.1",
    "vitest": "^1.3.1"
  }
}
