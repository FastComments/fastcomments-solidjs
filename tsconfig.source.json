{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "declaration": false,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "dist/source",
    "sourceMap": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "examples", "demo-dist", "src/**/*.test.ts", "src/**/*.test.tsx", "src/test-setup.ts"]
}
